VIDEOCUT_LLM_BASE_URL=https://api.openai.com/v1
VIDEOCUT_LLM_API_KEY=
VIDEOCUT_LLM_MODEL=gpt-4o-mini
VIDEOCUT_LLM_TIMEOUT=120
VIDEOCUT_TRANSLATION_BATCH_SIZE=25
VIDEOCUT_TRANSLATION_CONCURRENCY=1
VIDEOCUT_TRANSLATION_TIMING_ADAPT=0
VIDEOCUT_TRANSLATION_TARGET_COMPACT_CPS=4.6
VIDEOCUT_TRANSLATION_ADAPT_SLACK_CHARS=2
VIDEOCUT_TRANSLATION_ADAPT_PASSES=2
VIDEOCUT_TRANSLATION_ADAPT_MIN_CHARS=4
VIDEOCUT_TRANSLATION_AUDIO_REPAIR=1
VIDEOCUT_TRANSLATION_AUDIO_TARGET_PLAYBACK_RATE=1.0
VIDEOCUT_TRANSLATION_AUDIO_REPAIR_SLACK_SECONDS=0.05
VIDEOCUT_TRANSLATION_AUDIO_REPAIR_PASSES=2
VIDEOCUT_TRANSLATION_AUDIO_REPAIR_GROUP_SIZE=1
VIDEOCUT_PROTECTED_TERMS_PATH=translation_protected_terms.txt

VIDEOCUT_TTS_PROVIDER=cosyvoice
VIDEOCUT_TTS_VOICE=zh-CN-XiaoxiaoNeural
VIDEOCUT_TTS_RATE=+0%
VIDEOCUT_TTS_COMMAND=
VIDEOCUT_TTS_COMMAND_AUDIO_FORMAT=wav
VIDEOCUT_MINIMAX_BASE_URL=https://api.minimax.io
VIDEOCUT_MINIMAX_API_KEY=
VIDEOCUT_MINIMAX_MODEL=speech-2.8-turbo
VIDEOCUT_MINIMAX_VOICE_ID=Chinese (Mandarin)_News_Anchor
VIDEOCUT_MINIMAX_SPEED=1.0
VIDEOCUT_MINIMAX_VOLUME=1.0
VIDEOCUT_MINIMAX_PITCH=0
VIDEOCUT_MINIMAX_CONCURRENCY=4
VIDEOCUT_MINIMAX_AUDIO_FORMAT=mp3
VIDEOCUT_MINIMAX_SAMPLE_RATE=32000
VIDEOCUT_MINIMAX_BITRATE=128000
VIDEOCUT_MINIMAX_LANGUAGE_BOOST=Chinese
VIDEOCUT_MINIMAX_VOICE_CLONE=0
VIDEOCUT_MINIMAX_TIMEOUT=180
VIDEOCUT_COSYVOICE_PYTHON=./.venv-cosyvoice/bin/python
VIDEOCUT_COSYVOICE_REPO_DIR=.vendor/CosyVoice
VIDEOCUT_COSYVOICE_MODEL_DIR=.vendor/CosyVoice/pretrained_models/Fun-CosyVoice3-0.5B
VIDEOCUT_COSYVOICE_MODE=cross_lingual
VIDEOCUT_COSYVOICE_GROUP_SIZE=10
VIDEOCUT_REFERENCE_AUDIO_PATH=
VIDEOCUT_REFERENCE_TEXT=

VIDEOCUT_DUB_AUDIO_VOLUME=1.0
VIDEOCUT_ORIGINAL_AUDIO_VOLUME=0.0
VIDEOCUT_TIMING_MODE=natural
VIDEOCUT_MIN_PLAYBACK_RATE=0.6
VIDEOCUT_MAX_PLAYBACK_RATE=1.18
VIDEOCUT_MAX_SEGMENT_LAG=0.8
VIDEOCUT_MIN_SEGMENT_GAP=0.05
VIDEOCUT_MAX_OPENING_SILENCE=0.35
VIDEOCUT_MAX_GLOBAL_SHIFT=2.5
VIDEOCUT_TRIM_TTS_SILENCE=1
VIDEOCUT_TTS_SILENCE_THRESHOLD_DB=-35
VIDEOCUT_TTS_SILENCE_MIN_DURATION=0.05
VIDEOCUT_TTS_KEEP_SILENCE=0.02

VIDEOCUT_BURN_SUBTITLES=1
VIDEOCUT_SUBTITLE_FONT=Arial Unicode MS
VIDEOCUT_SUBTITLE_FONT_PATH=
VIDEOCUT_SUBTITLE_FONT_SIZE=18
VIDEOCUT_SUBTITLE_OVERLAY_CONCURRENCY=4
VIDEOCUT_VIDEO_PRESET=medium
VIDEOCUT_VIDEO_CRF=20
VIDEOCUT_FFMPEG_BIN=ffmpeg
VIDEOCUT_FFPROBE_BIN=ffprobe

VIDEOCUT_ASR_MODEL=small
VIDEOCUT_ASR_DEVICE=auto
VIDEOCUT_ASR_COMPUTE_TYPE=int8
